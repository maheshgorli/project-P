# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real credentials.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# NASA EONET API key (optional for development)
# EONET public endpoints work with "DEMO_KEY" but it is rate-limited.
# Get a free production key at: https://api.nasa.gov/
NASA_API_KEY=your_nasa_api_key_here

# Sentinel Hub / Copernicus Data Space Ecosystem credentials (required)
# Create OAuth clients at: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here
